<% content_for :title, "Visits" %>

<h1>Visits</h1>

<div id="visits">
  <% @visits.each do |visit| %>
    <%= render visit %>
    <p>
      <%= link_to "Show this visit", visit %>
    </p>
  <% end %>
  <%= link_to "Create New Visit", new_visit_path %>
</div>

<h1>Shops</h1>

<%= form_with url: shops_path, method: :get, local: true do |form| %>
  <%= form.text_field :query, value: params[:query], placeholder: "Search shops..." %>
  <%= form.submit "Search" %>
<% end %>

<%= form_with url: shops_path, method: :get, local: true do |form| %>
  <%= form.select :city,
    options_for_select(
      Shop.distinct.pluck(:city),
      params[:city]
    ),
    { include_blank: "All cities" },
    { onchange: "this.form.submit();" } %>
<% end %>

<div id="shops">
  <% @shops.each do |shop| %>
    <%= render shop %>
    <p>
      <%= link_to "Show this shop", shop %>
    </p>
  <% end %>
</div>
